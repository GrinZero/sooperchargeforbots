{
  "name": "@sourcebug/looi-sdk",
  "version": "0.1.0-alpha.0",
  "description": "Experimental transport-agnostic SDK for controlling LOOI Robot over BLE.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
